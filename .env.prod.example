# ──────────────────────────────────────────────────────────────────────
# Variables d'environnement – PRODUCTION
# Copier en .env et remplir TOUTES les valeurs CHANGE_ME avant le déploiement.
#
# Génération de secrets :
#   JWT_SECRET          : python -c "import secrets; print(secrets.token_urlsafe(48))"
#   MODEL_ENCRYPTION_KEY: python -c "import secrets; print(secrets.token_urlsafe(32))"
#   Mots de passe       : python -c "import secrets; print(secrets.token_urlsafe(24))"
# ──────────────────────────────────────────────────────────────────────

# ── JWT ──────────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_strong_random_secret_min_48_chars

# ── Comptes applicatifs (remplacer les valeurs par défaut) ───────────
ADMIN_PASSWORD=CHANGE_ME_admin_password
AGENT_PASSWORD=CHANGE_ME_agent_password

# ── Chiffrement modèle (AES-256-GCM) ────────────────────────────────
MODEL_ENCRYPTION_KEY=CHANGE_ME_strong_encryption_key_min_32_chars

# ── CORS – origines autorisées ───────────────────────────────────────
# En local  : https://localhost:8443
# En déploiement : remplacer par le domaine réel
ALLOWED_ORIGINS=https://localhost:8443

# ── PostgreSQL ───────────────────────────────────────────────────────
POSTGRES_USER=secure_ai
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=ai_metrics

# ── Redis ────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_strong_redis_password

# ── Grafana ──────────────────────────────────────────────────────────
GRAFANA_PASSWORD=CHANGE_ME_grafana_admin_password
