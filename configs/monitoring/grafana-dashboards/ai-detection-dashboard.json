{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Vue d'ensemble",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Indique si l'API est joignable. BLEU = en ligne, ROUGE = hors service.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            { "options": { "0": { "color": "red", "text": "HORS SERVICE" }, "1": { "color": "blue", "text": "EN LIGNE" } }, "type": "value" }
          ],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "blue", "value": 1 } ] }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "id": 1,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "targets": [ { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "up{job=\"secured-api\"}", "legendFormat": "API", "refId": "A" } ],
      "title": "API – État",
      "type": "stat"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Nombre total d'images analysées depuis le démarrage de l'API. Compteur exact — augmente de 1 à chaque prédiction.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "blue", "value": null } ] },
          "unit": "none", "decimals": 0, "noValue": "0"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "id": 2,
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "targets": [ { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(ai_predictions_total) or vector(0)", "legendFormat": "", "refId": "A" } ],
      "title": "Images analysées – total",
      "type": "stat"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Nombre total de requêtes bloquées par le WAF depuis le démarrage. Vert = normal, orange ≥ 5, rouge ≥ 20.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "orange", "value": 5 }, { "color": "red", "value": 20 } ] },
          "unit": "none", "decimals": 0, "noValue": "0"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "id": 3,
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "targets": [ { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(security_attacks_blocked_total) or vector(0)", "legendFormat": "", "refId": "A" } ],
      "title": "Blocages WAF – total",
      "type": "stat"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Latence au 95e percentile pour /predict (2 dernières minutes). 95 % des requêtes répondent plus vite que cette valeur. Vert < 100 ms, orange > 100 ms, rouge > 500 ms.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "orange", "value": 100 }, { "color": "red", "value": 500 } ] },
          "unit": "ms", "decimals": 0, "noValue": "N/A"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "id": 4,
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "targets": [ { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket{endpoint=\"/predict\"}[2m]))) * 1000", "legendFormat": "P95", "refId": "A" } ],
      "title": "Latence P95 – /predict",
      "type": "stat"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 101,
      "title": "Prédictions IA – évolution dans le temps",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Compteur cumulé de prédictions. La courbe monte d'un cran à chaque image analysée. Vert = images jugées sûres. Rouge = images dangereuses (arme détectée). La valeur finale correspond au total affiché dans la vue d'ensemble.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "stepAfter",
            "fillOpacity": 10,
            "lineWidth": 2,
            "showPoints": "always",
            "pointSize": 6,
            "spanNulls": false
          },
          "unit": "none",
          "decimals": 0,
          "min": 0
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Sûres" },      "properties": [ { "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } } ] },
          { "matcher": { "id": "byName", "options": "Dangereuses" }, "properties": [ { "id": "color", "value": { "fixedColor": "red",   "mode": "fixed" } } ] }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "id": 7,
      "options": {
        "legend": { "calcs": ["last"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "ai_predictions_total{prediction=\"safe\"}",      "legendFormat": "Sûres",      "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "ai_predictions_total{prediction=\"dangerous\"}", "legendFormat": "Dangereuses", "refId": "B" }
      ],
      "title": "Prédictions cumulées – Sûres vs Dangereuses",
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Compteur cumulé de blocages WAF. La courbe monte à chaque requête bloquée. Chaque couleur = une raison : 'Rate limit exceeded' (IP dépasse 50 req/min), 'adversarial_input_detected' (image perturbée).",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "stepAfter",
            "fillOpacity": 10,
            "lineWidth": 2,
            "showPoints": "always",
            "pointSize": 6,
            "spanNulls": false
          },
          "unit": "none",
          "decimals": 0,
          "min": 0
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "id": 9,
      "options": {
        "legend": { "calcs": ["last"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "security_attacks_blocked_total", "legendFormat": "{{reason}}", "refId": "A" }
      ],
      "title": "Blocages WAF cumulés – par raison",
      "type": "timeseries"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 102,
      "title": "Performance – latence et débit",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Latence de /predict en ms. P50 = médiane (la moitié des requêtes sont plus rapides). P95 = les 5 % les plus lents. Seuil d'alerte : 500 ms.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineInterpolation": "smooth", "lineWidth": 2, "showPoints": "never", "spanNulls": true },
          "unit": "ms", "decimals": 0
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "id": 6,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.50, sum by (le) (rate(http_request_duration_seconds_bucket{endpoint=\"/predict\"}[2m]))) * 1000", "legendFormat": "P50 – médiane",   "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket{endpoint=\"/predict\"}[2m]))) * 1000", "legendFormat": "P95 – cas lents", "refId": "B" }
      ],
      "title": "Latence /predict en ms – P50 et P95",
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Requêtes reçues par seconde (taux moyen sur 2 min). Bleu = endpoint /predict. Vert = toutes les routes (auth, admin…). Un écart signale du trafic hors prédictions.",
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "blue", "mode": "fixed" },
          "custom": { "drawStyle": "line", "fillOpacity": 15, "lineInterpolation": "smooth", "lineWidth": 2, "showPoints": "never", "spanNulls": true },
          "unit": "reqps", "decimals": 3
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Toutes requêtes" }, "properties": [ { "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } } ] }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "id": 5,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(http_requests_total{endpoint=\"/predict\"}[2m])",  "legendFormat": "Prédictions /predict", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(http_requests_total[2m]))", "legendFormat": "Toutes requêtes",       "refId": "B" }
      ],
      "title": "Débit – requêtes par seconde",
      "type": "timeseries"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "id": 103,
      "title": "Erreurs HTTP",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Compteur cumulé d'erreurs HTTP. Orange = 4xx (requête invalide : fichier non image, auth échouée, rejeté par le WAF). Rouge = 5xx (panne interne : modèle non chargé, exception). La courbe monte à chaque erreur.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "stepAfter",
            "fillOpacity": 10,
            "lineWidth": 2,
            "showPoints": "always",
            "pointSize": 5,
            "spanNulls": false
          },
          "unit": "none",
          "decimals": 0,
          "min": 0
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "4xx – requête invalide" }, "properties": [ { "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } } ] },
          { "matcher": { "id": "byName", "options": "5xx – erreur serveur" },   "properties": [ { "id": "color", "value": { "fixedColor": "red",    "mode": "fixed" } } ] }
        ]
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 24 },
      "id": 10,
      "options": {
        "legend": { "calcs": ["last"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(http_requests_total{status=~\"4..\"}) or vector(0)", "legendFormat": "4xx – requête invalide", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(http_requests_total{status=~\"5..\"}) or vector(0)", "legendFormat": "5xx – erreur serveur",   "refId": "B" }
      ],
      "title": "Erreurs HTTP cumulées – 4xx et 5xx",
      "type": "timeseries"
    }

  ],
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["ai", "security", "secured", "detection"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
