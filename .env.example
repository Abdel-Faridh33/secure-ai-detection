# Environment configuration

# GPU Configuration
CUDA_VISIBLE_DEVICES=0

# API Configuration
API_PORT=8000
API_HOST=0.0.0.0

# Model Configuration
MODEL_TYPE=secured
MODEL_PATH=/workspace/models

# Security Configuration
ENABLE_DEFENSES=true
RATE_LIMIT=100

# JWT Secret – générer avec : python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=CHANGE_ME_strong_random_secret_key_min_32_chars

# Clé de chiffrement AES-256-GCM du modèle (au moins 20 caractères)
MODEL_ENCRYPTION_KEY=CHANGE_ME_strong_encryption_key_for_model

# CORS – origines autorisées (séparées par virgule)
ALLOWED_ORIGINS=http://localhost:8800,http://localhost:3000

# Database Configuration
POSTGRES_USER=secure_ai
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=ai_metrics
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_strong_redis_password

# Monitoring
GRAFANA_PASSWORD=CHANGE_ME_grafana_admin_password
PROMETHEUS_PORT=9090
